# Database
DATABASE_URL=postgres://medilink:medilink_dev@localhost:5432/medilink_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=medilink
MINIO_SECRET_KEY=medilink_minio_dev
MINIO_BUCKET=medilink-lab-reports
MINIO_USE_SSL=false

# Authentication
JWT_SECRET=your-minimum-32-character-jwt-secret-here
ENCRYPTION_KEY=your-exactly-32-byte-encryption-key!

# Email (Resend)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@medilink.health

# LLM Providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GEMINI_API_KEY=your_gemini_key_here

# External APIs
OPENFDA_BASE_URL=https://api.fda.gov
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# Push Notifications
FCM_SERVER_KEY=your_fcm_key_here

# Application
APP_ENV=development
APP_PORT=8080
WORKER_PORT=8081
GIN_MODE=debug
