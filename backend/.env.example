# Database
DATABASE_URL=postgres://medilink:medilink_dev@localhost:5432/medilink_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=medilink
MINIO_SECRET_KEY=medilink_minio_dev
MINIO_BUCKET=medilink-lab-reports
MINIO_USE_SSL=false

# Authentication
JWT_SECRET=your-minimum-32-character-jwt-secret-here
ENCRYPTION_KEY=your-exactly-32-byte-encryption-key!

# Email (Resend — using shared domain, no custom domain needed)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# LLM — Gemini is PRIMARY, Ollama is optional fallback
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1:8b

# External APIs
OPENFDA_BASE_URL=https://api.fda.gov
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# Firebase Push Notifications (Admin SDK — NOT legacy FCM server key)
# Project: MediLink | ID: medilink-0 | Number: 654953494919
FIREBASE_SERVICE_ACCOUNT_PATH=./medilink-firebase-adminsdk.json
FIREBASE_PROJECT_ID=medilink-0

# Application
APP_ENV=development
APP_PORT=8080
WORKER_PORT=8081
GIN_MODE=debug
